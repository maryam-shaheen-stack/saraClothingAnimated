# Server
PORT=3000
# IMPORTANT: keep this as "development" for local testing (npm run dev).
# The session cookie is marked Secure when NODE_ENV=production, which
# browsers refuse to store over plain http://localhost — that was the
# cause of the login/register "no error, just bounces back" bug.
# Set NODE_ENV=production ONLY in Vercel's project environment variables
# (Settings -> Environment Variables), never in this local .env file.
NODE_ENV=development

