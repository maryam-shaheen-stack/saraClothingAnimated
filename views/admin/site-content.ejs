<div class="admin-page-header">
  <h1>Homepage Content</h1>
  <button type="button" class="btn btn--primary" id="openAddSlideModal">
    <span class="btn__label">Add Hero Slide</span>
  </button>
</div>

<div class="admin-panel">
  <p class="admin-panel__subheading">
    These slides play automatically on the homepage's first section (2–3 slides works best). Use the arrows to reorder — the top slide plays first.
  </p>

  <% if (typeof content !== 'undefined' && content.heroSlides.length > 0) { %>
    <% const sortedSlides = [...content.heroSlides].sort((a, b) => a.order - b.order); %>
    <div class="slide-grid" id="slideGrid">
      <% sortedSlides.forEach(function(slide, index) { %>
        <div class="slide-card" data-slide-id="<%= slide._id %>">
          <div class="slide-card__image">
            <img src="<%= slide.image %>" alt="<%= slide.headline || 'Hero slide' %>" width="220" height="140" loading="lazy">
            <span class="slide-card__badge">Slide <%= index + 1 %></span>
          </div>
          <div class="slide-card__body">
            <p class="slide-card__headline"><%= slide.headline || '(No headline)' %></p>
            <% if (slide.subtext) { %><p class="slide-card__subtext"><%= slide.subtext %></p><% } %>
          </div>
          <div class="slide-card__actions">
            <button type="button" class="btn btn--text move-slide-btn" data-direction="up" data-slide-id="<%= slide._id %>" <%= index === 0 ? 'disabled' : '' %> aria-label="Move slide earlier">&#8593; Move Up</button>
            <button type="button" class="btn btn--text move-slide-btn" data-direction="down" data-slide-id="<%= slide._id %>" <%= index === sortedSlides.length - 1 ? 'disabled' : '' %> aria-label="Move slide later">&#8595; Move Down</button>
            <button type="button" class="btn btn--text edit-slide-btn" data-slide-id="<%= slide._id %>">Edit</button>
            <button type="button" class="btn btn--text btn--danger delete-slide-btn" data-slide-id="<%= slide._id %>">Delete</button>
          </div>
        </div>
      <% }); %>
    </div>
  <% } else { %>
    <p class="empty-state">No hero slides yet — add 2 or 3 so the homepage carousel has something to play. Until you add one, the homepage falls back to a single default image.</p>
  <% } %>
</div>

<div class="admin-page-header admin-page-header--secondary">
  <h1>Our Story Section</h1>
</div>

<div class="admin-panel">
  <p class="admin-panel__subheading">This feeds the "Our Story" section right under the hero on the homepage.</p>

  <form id="storyForm" novalidate>
    <div class="story-form__layout">
      <div class="story-form__image-preview">
        <img
          id="storyImagePreview"
          src="<%= typeof content !== 'undefined' && content.story.image ? content.story.image : '/images/about/story-thumb.jpg' %>"
          alt="Our Story preview"
          width="200"
          height="200"
        >
      </div>
      <div class="story-form__fields">
        <div class="form-group">
          <label for="storyHeading">Heading</label>
          <input type="text" id="storyHeading" name="heading" value="<%= typeof content !== 'undefined' ? content.story.heading : '' %>" required aria-describedby="storyHeadingError">
          <span class="form-error" id="storyHeadingError" role="alert"></span>
        </div>

        <div class="form-group">
          <label for="storyText">Story Text</label>
          <textarea id="storyText" name="text" rows="4" required aria-describedby="storyTextError"><%= typeof content !== 'undefined' ? content.story.text : '' %></textarea>
          <span class="form-error" id="storyTextError" role="alert"></span>
        </div>

        <div class="form-group">
          <label for="storyImage">Replace Image (optional)</label>
          <input type="file" id="storyImage" name="image" accept="image/*">
        </div>
      </div>
    </div>

    <div class="modal__footer modal__footer--inline">
      <button type="submit" class="btn btn--primary" id="storySubmitBtn">
        <span class="btn__label">Save Story Section</span>
      </button>
    </div>

    <p class="form-feedback" id="storyFormFeedback" role="status" aria-live="polite"></p>
  </form>
</div>

<div class="modal" id="slideModal" hidden>
  <div class="modal__overlay" data-close-modal></div>
  <div class="modal__panel" role="dialog" aria-modal="true" aria-labelledby="slideModalTitle">
    <div class="modal__header">
      <h2 id="slideModalTitle">Add Hero Slide</h2>
      <button type="button" class="modal__close" data-close-modal aria-label="Close">
        <img src="/icons/close.svg" alt="" width="18" height="18">
      </button>
    </div>

    <form id="slideForm" novalidate>
      <input type="hidden" id="slideId" name="slideId">

      <div class="form-group">
        <label for="slideImage">Slide Image <span id="slideImageRequiredHint">(required)</span></label>
        <input type="file" id="slideImage" name="image" accept="image/*">
        <span class="form-error" id="slideImageError" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="slideHeadline">Headline</label>
        <input type="text" id="slideHeadline" name="headline" aria-describedby="slideHeadlineError">
        <span class="form-error" id="slideHeadlineError" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="slideSubtext">Subtext</label>
        <textarea id="slideSubtext" name="subtext" rows="2"></textarea>
      </div>

      <div class="form-group">
        <label for="slideButtonText">Button Text</label>
        <input type="text" id="slideButtonText" name="buttonText" placeholder="e.g. Shop the Collection">
      </div>

      <div class="form-group">
        <label for="slideButtonLink">Button Link</label>
        <input type="text" id="slideButtonLink" name="buttonLink" placeholder="e.g. /shop">
      </div>

      <div class="modal__footer">
        <button type="button" class="btn btn--outline" data-close-modal>Cancel</button>
        <button type="submit" class="btn btn--primary" id="slideSubmitBtn">
          <span class="btn__label">Save Slide</span>
        </button>
      </div>

      <p class="form-feedback" id="slideFormFeedback" role="status" aria-live="polite"></p>
    </form>
  </div>
</div>
