<div class="admin-page-header">
  <h1>Newsletter Subscribers</h1>
  <button type="button" class="btn btn--outline" id="exportSubscribersBtn">
    <span class="btn__label">Export CSV</span>
  </button>
</div>

<div class="admin-panel">
  <p class="admin-panel__subheading">
    <% if (typeof subscribers !== 'undefined') { %>
      <%= subscribers.length %> total subscribers
    <% } %>
  </p>

  <% if (typeof subscribers !== 'undefined' && subscribers.length > 0) { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th scope="col">Email</th>
          <th scope="col">Subscribed On</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% subscribers.forEach(function(subscriber) { %>
          <tr>
            <td><%= subscriber.email %></td>
            <td><%= new Date(subscriber.createdAt).toLocaleDateString() %></td>
            <td class="admin-table__actions">
              <button type="button" class="btn btn--text btn--danger delete-subscriber-btn" data-subscriber-id="<%= subscriber._id %>">Remove</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <p class="empty-state">No subscribers yet.</p>
  <% } %>
</div>
