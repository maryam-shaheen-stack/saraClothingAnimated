<div class="admin-page-header">
  <h1>Manage Testimonials</h1>
  <button type="button" class="btn btn--primary" id="openAddTestimonialModal">
    <span class="btn__label">Add Testimonial</span>
  </button>
</div>

<div class="admin-panel">
  <% if (typeof testimonials !== 'undefined' && testimonials.length > 0) { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th scope="col">Name</th>
          <th scope="col">Rating</th>
          <th scope="col">Message</th>
          <th scope="col">Status</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% testimonials.forEach(function(testimonial) { %>
          <tr>
            <td><%= testimonial.name %></td>
            <td><%= testimonial.rating %> / 5</td>
            <td class="admin-table__truncate"><%= testimonial.message %></td>
            <td>
              <span class="status-badge <%= testimonial.published ? 'status-badge--in-stock' : 'status-badge--unread' %>">
                <%= testimonial.published ? 'Published' : 'Hidden' %>
              </span>
            </td>
            <td class="admin-table__actions">
              <button type="button" class="btn btn--text edit-testimonial-btn" data-testimonial-id="<%= testimonial._id %>">Edit</button>
              <button type="button" class="btn btn--text btn--danger delete-testimonial-btn" data-testimonial-id="<%= testimonial._id %>">Delete</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <p class="empty-state">No testimonials added yet.</p>
  <% } %>
</div>

<div class="modal" id="testimonialModal" hidden>
  <div class="modal__overlay" data-close-modal></div>
  <div class="modal__panel" role="dialog" aria-modal="true" aria-labelledby="testimonialModalTitle">
    <div class="modal__header">
      <h2 id="testimonialModalTitle">Add Testimonial</h2>
      <button type="button" class="modal__close" data-close-modal aria-label="Close">
        <img src="/icons/close.svg" alt="" width="18" height="18">
      </button>
    </div>

    <form id="testimonialForm" novalidate>
      <input type="hidden" id="testimonialId" name="testimonialId">

      <div class="form-group">
        <label for="testimonialName">Customer Name</label>
        <input type="text" id="testimonialName" name="name" required>
      </div>

      <div class="form-group">
        <label for="testimonialLocation">Location (optional)</label>
        <input type="text" id="testimonialLocation" name="location">
      </div>

      <div class="form-group">
        <label for="testimonialRating">Rating</label>
        <select id="testimonialRating" name="rating" required>
          <option value="5">5 Stars</option>
          <option value="4">4 Stars</option>
          <option value="3">3 Stars</option>
          <option value="2">2 Stars</option>
          <option value="1">1 Star</option>
        </select>
      </div>

      <div class="form-group">
        <label for="testimonialMessage">Message</label>
        <textarea id="testimonialMessage" name="message" rows="4" required></textarea>
      </div>

      <div class="form-group form-group--checkbox">
        <label>
          <input type="checkbox" id="testimonialPublished" name="published">
          Publish on website
        </label>
      </div>

      <div class="modal__footer">
        <button type="button" class="btn btn--outline" data-close-modal>Cancel</button>
        <button type="submit" class="btn btn--primary" id="testimonialSubmitBtn">
          <span class="btn__label">Save Testimonial</span>
        </button>
      </div>

      <p class="form-feedback" id="testimonialFormFeedback" role="status" aria-live="polite"></p>
    </form>
  </div>
</div>
