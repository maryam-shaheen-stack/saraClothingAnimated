<div class="admin-page-header">
  <h1>Manage Announcements</h1>
  <button type="button" class="btn btn--primary" id="openAddAnnouncementModal">
    <span class="btn__label">Add Announcement</span>
  </button>
</div>

<div class="admin-panel">
  <p class="admin-panel__subheading">Active announcements appear as a banner at the top of every page on the site. Visitors can dismiss a banner, and it won't reappear for them.</p>

  <% if (typeof announcements !== 'undefined' && announcements.length > 0) { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th scope="col">Message</th>
          <th scope="col">Type</th>
          <th scope="col">Status</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% announcements.forEach(function(announcement) { %>
          <tr>
            <td class="admin-table__truncate"><%= announcement.message %></td>
            <td style="text-transform: capitalize;"><%= announcement.type %></td>
            <td>
              <span class="status-badge <%= announcement.active ? 'status-badge--in-stock' : 'status-badge--unread' %>">
                <%= announcement.active ? 'Active' : 'Hidden' %>
              </span>
            </td>
            <td class="admin-table__actions">
              <button type="button" class="btn btn--text edit-announcement-btn" data-announcement-id="<%= announcement._id %>">Edit</button>
              <button type="button" class="btn btn--text btn--danger delete-announcement-btn" data-announcement-id="<%= announcement._id %>">Delete</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <p class="empty-state">No announcements yet. Add one to display a banner across the site.</p>
  <% } %>
</div>

<div class="modal" id="announcementModal" hidden>
  <div class="modal__overlay" data-close-modal></div>
  <div class="modal__panel" role="dialog" aria-modal="true" aria-labelledby="announcementModalTitle">
    <div class="modal__header">
      <h2 id="announcementModalTitle">Add Announcement</h2>
      <button type="button" class="modal__close" data-close-modal aria-label="Close">
        <img src="/icons/close.svg" alt="" width="18" height="18">
      </button>
    </div>

    <form id="announcementForm" novalidate>
      <input type="hidden" id="announcementId" name="announcementId">

      <div class="form-group">
        <label for="announcementMessage">Message</label>
        <textarea id="announcementMessage" name="message" rows="3" required aria-describedby="announcementMessageError"></textarea>
        <span class="form-error" id="announcementMessageError" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="announcementType">Type</label>
        <select id="announcementType" name="type" required>
          <option value="sale">Sale</option>
          <option value="info">Info</option>
          <option value="urgent">Urgent</option>
        </select>
        <p class="form-hint">Controls the banner color: sale (maroon), info (dark neutral), urgent (red).</p>
      </div>

      <div class="form-group">
        <label for="announcementLink">Link URL (optional)</label>
        <input type="text" id="announcementLink" name="link" placeholder="/shop?sort=newest">
      </div>

      <div class="form-group">
        <label for="announcementLinkText">Link Text (optional)</label>
        <input type="text" id="announcementLinkText" name="linkText" placeholder="Shop Now">
      </div>

      <div class="form-group form-group--checkbox">
        <label>
          <input type="checkbox" id="announcementActive" name="active" checked>
          Show on website
        </label>
      </div>

      <div class="modal__footer">
        <button type="button" class="btn btn--outline" data-close-modal>Cancel</button>
        <button type="submit" class="btn btn--primary" id="announcementSubmitBtn">
          <span class="btn__label">Save Announcement</span>
        </button>
      </div>

      <p class="form-feedback" id="announcementFormFeedback" role="status" aria-live="polite"></p>
    </form>
  </div>
</div>
