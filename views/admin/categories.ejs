<div class="admin-page-header">
  <h1>Manage Categories</h1>
  <button type="button" class="btn btn--primary" id="openAddCategoryModal">
    <span class="btn__label">Add Category</span>
  </button>
</div>

<div class="admin-panel">
  <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th scope="col">Image</th>
          <th scope="col">Name</th>
          <th scope="col">Products</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% categories.forEach(function(category) { %>
          <tr>
            <td><img src="<%= category.image %>" alt="<%= category.name %>" width="48" height="48" loading="lazy"></td>
            <td><%= category.name %></td>
            <td><%= category.productCount || 0 %></td>
            <td class="admin-table__actions">
              <button type="button" class="btn btn--text edit-category-btn" data-category-id="<%= category._id %>">Edit</button>
              <button type="button" class="btn btn--text btn--danger delete-category-btn" data-category-id="<%= category._id %>">Delete</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <p class="empty-state">No categories added yet.</p>
  <% } %>
</div>

<div class="modal" id="categoryModal" hidden>
  <div class="modal__overlay" data-close-modal></div>
  <div class="modal__panel" role="dialog" aria-modal="true" aria-labelledby="categoryModalTitle">
    <div class="modal__header">
      <h2 id="categoryModalTitle">Add Category</h2>
      <button type="button" class="modal__close" data-close-modal aria-label="Close">
        <img src="/icons/close.svg" alt="" width="18" height="18">
      </button>
    </div>

    <form id="categoryForm" novalidate>
      <input type="hidden" id="categoryId" name="categoryId">

      <div class="form-group">
        <label for="categoryName">Category Name</label>
        <input type="text" id="categoryName" name="name" required aria-describedby="categoryNameError">
        <span class="form-error" id="categoryNameError" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="categoryImage">Category Image</label>
        <input type="file" id="categoryImage" name="image" accept="image/*">
      </div>

      <div class="modal__footer">
        <button type="button" class="btn btn--outline" data-close-modal>Cancel</button>
        <button type="submit" class="btn btn--primary" id="categorySubmitBtn">
          <span class="btn__label">Save Category</span>
        </button>
      </div>

      <p class="form-feedback" id="categoryFormFeedback" role="status" aria-live="polite"></p>
    </form>
  </div>
</div>
