<div class="admin-page-header">
  <h1>Manage Products</h1>
  <button type="button" class="btn btn--primary" id="openAddProductModal">
    <span class="btn__label">Add Product</span>
  </button>
</div>

<div class="admin-panel">
  <% if (typeof products !== 'undefined' && products.length > 0) { %>
    <table class="admin-table">
      <thead>
        <tr>
          <th scope="col">Image</th>
          <th scope="col">Name</th>
          <th scope="col">Category</th>
          <th scope="col">Price</th>
          <th scope="col">Stock</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(function(product) { %>
          <tr>
            <td><img src="<%= product.image %>" alt="<%= product.name %>" width="48" height="60" loading="lazy"></td>
            <td><%= product.name %></td>
            <td><%= (product.category && product.category.name) ? product.category.name : '' %></td>
            <td>Rs. <%= product.price.toLocaleString() %></td>
            <td>
              <span class="status-badge <%= product.stock > 0 ? 'status-badge--in-stock' : 'status-badge--out-of-stock' %>">
                <%= product.stock > 0 ? product.stock + ' in stock' : 'Sold out' %>
              </span>
            </td>
            <td class="admin-table__actions">
              <button type="button" class="btn btn--text edit-product-btn" data-product-id="<%= product._id %>">Edit</button>
              <button type="button" class="btn btn--text btn--danger delete-product-btn" data-product-id="<%= product._id %>">Delete</button>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } else { %>
    <p class="empty-state">No products added yet. Click "Add Product" to create your first listing.</p>
  <% } %>
</div>

<div class="modal" id="productModal" hidden>
  <div class="modal__overlay" data-close-modal></div>
  <div class="modal__panel" role="dialog" aria-modal="true" aria-labelledby="productModalTitle">
    <div class="modal__header">
      <h2 id="productModalTitle">Add Product</h2>
      <button type="button" class="modal__close" data-close-modal aria-label="Close">
        <img src="/icons/close.svg" alt="" width="18" height="18">
      </button>
    </div>

    <form id="productForm" novalidate>
      <input type="hidden" id="productId" name="productId">
      <input type="hidden" id="removeGalleryImages" name="removeGalleryImages" value="[]">

      <div class="form-group">
        <label for="productName">Product Name</label>
        <input type="text" id="productName" name="name" required aria-describedby="productNameError">
        <span class="form-error" id="productNameError" role="alert"></span>
      </div>

      <div class="form-group">
        <label for="productCategory">Category</label>
        <select id="productCategory" name="category" required>
          <option value="">Select a category</option>
          <% if (typeof categories !== 'undefined') { %>
            <% categories.forEach(function(category) { %>
              <option value="<%= category._id %>"><%= category.name %></option>
            <% }); %>
          <% } %>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="productPrice">Price (Rs.)</label>
          <input type="number" id="productPrice" name="price" min="0" required>
        </div>
        <div class="form-group">
          <label for="productStock">Stock Quantity</label>
          <input type="number" id="productStock" name="stock" min="0" required>
        </div>
      </div>

      <div class="form-group">
        <label for="productDescription">Description</label>
        <textarea id="productDescription" name="description" rows="4"></textarea>
      </div>

      <div class="form-group">
        <label>Available Sizes</label>
        <div class="checkbox-group" id="productSizesGroup">
          <% ['XS','S','M','L','XL','XXL'].forEach(function(size) { %>
            <label class="checkbox-group__item">
              <input type="checkbox" name="sizes" value="<%= size %>"> <%= size %>
            </label>
          <% }); %>
        </div>
      </div>

      <div class="form-group">
        <label for="productImage">Main Image <span id="productImageRequiredHint">(required)</span></label>
        <input type="file" id="productImage" name="image" accept="image/*">
      </div>

      <div class="form-group">
        <label for="productGallery">Additional Photos (up to 5)</label>
        <input type="file" id="productGallery" name="gallery" accept="image/*" multiple>
        <span class="form-hint">Shown as extra thumbnails on the product page. Optional.</span>
        <div id="existingGalleryPreview" class="gallery-preview"></div>
      </div>

      <div class="modal__footer">
        <button type="button" class="btn btn--outline" data-close-modal>Cancel</button>
        <button type="submit" class="btn btn--primary" id="productSubmitBtn">
          <span class="btn__label">Save Product</span>
        </button>
      </div>

      <p class="form-feedback" id="productFormFeedback" role="status" aria-live="polite"></p>
    </form>
  </div>
</div>
