<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>

  <!-- Sitewide ambient background: mall photo + soft gold shine + roaming
       glow circles. Pure CSS, GPU-cheap (transform-only animations) — sits
       behind every page's content without slowing anything down. -->
  <div class="ambient-bg" aria-hidden="true">
    <div class="ambient-bg__photo"></div>
    <div class="ambient-bg__shine"></div>
    <div class="ambient-bg__wash"></div>
    <div class="ambient-bg__orb ambient-bg__orb--1"></div>
    <div class="ambient-bg__orb ambient-bg__orb--2"></div>
    <div class="ambient-bg__orb ambient-bg__orb--3"></div>
    <div class="ambient-bg__orb ambient-bg__orb--4"></div>
  </div>

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <%- include('../partials/announcement-bar') %>
  <%- include('../partials/navbar') %>

  <main id="main-content">
    <%- body %>
  </main>

  <%- include('../partials/footer') %>

  <!-- Global scripts -->
  <script src="/js/perf-pause.js" defer></script>
  <script src="/js/animations.js" defer></script>
  <script src="/js/main.js" defer></script>
  <script src="/js/3d-effects.js" defer></script>
  <script src="/js/hero-stars.js" defer></script>

  <!-- Page-specific script -->
  <% if (typeof pageScript !== 'undefined') { %>
    <script src="/js/pages/<%= pageScript %>.js" defer></script>
  <% } %>

  <!-- Three.js-powered hero starfield (homepage only — heavy library,
       so it's scoped strictly to the page that uses it). Falls back
       silently to the existing CSS twinkling stars if this fails to load. -->
  <% if (typeof pageScript !== 'undefined' && pageScript === 'home') { %>
    <script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js" defer></script>
    <script src="/js/hero-three.js" defer></script>
  <% } %>

</body>
</html>
