<article class="product-card">
  <a href="/shop/<%= product._id %>" class="product-card__link">
    <div class="product-card__shine"></div>
    <div class="product-card__image-wrapper">
      <img
        src="<%= product.image %>"
        alt="<%= product.name %>"
        width="400"
        height="500"
        loading="lazy"
        class="product-card__image"
      >

      <% if (product.stock === 0) { %>
        <span class="product-card__badge product-card__badge--sold-out">Sold Out</span>
      <% } else if (product.discountPrice) { %>
        <span class="product-card__badge product-card__badge--sale">Sale</span>
      <% } %>
    </div>

    <div class="product-card__info">
      <p class="product-card__category"><%= (product.category && product.category.name) ? product.category.name : '' %></p>
      <h3 class="product-card__name"><%= product.name %></h3>

      <p class="product-card__price">
        <% if (product.discountPrice) { %>
          <span class="product-card__price--current"><%= 'Rs. ' + product.discountPrice.toLocaleString() %></span>
          <span class="product-card__price--original"><%= 'Rs. ' + product.price.toLocaleString() %></span>
        <% } else { %>
          <span class="product-card__price--current"><%= 'Rs. ' + product.price.toLocaleString() %></span>
        <% } %>
      </p>
    </div>
  </a>
</article>
